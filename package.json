{
  "name": "strategists-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:crm": "npm run dev --workspace=apps/crm",
    "dev:lms": "npm run dev --workspace=apps/lms",
    "build:crm": "npm run build --workspace=apps/crm",
    "build:lms": "npm run build --workspace=apps/lms",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.8.14"
  }
}
